# Build correctness
build --cxxopt=-std=c++17

# Treat headers from external repositories as system headers (-isystem) instead
# of -I/-iquote.  This keeps warnings originating inside third-party headers
# (spdlog/fmt, grpc, c-ares) from tripping our -Werror, while our own first-party
# headers still get full warning coverage.
build --features=external_include_paths

# Disable Bazel's layering_check.  grpc 1.76's macOS CoreFoundation event engine
# (cf_event_engine) includes a couple of internal headers without declaring the
# dep, which only fails under layering_check — an upstream issue we can't fix.
build --features=-layering_check

# Treat warnings as errors for our own C++ code only.
# A global --cxxopt=-Werror would also apply to external deps (abseil, grpc,
# protobuf, spdlog), which emit warnings we cannot fix.  --per_file_copt scopes
# -Wall -Werror to first-party sources under cpp/ by matching their exec path.
build --per_file_copt=^cpp/.*\.cc$@-Wall,-Werror

# Build UX
build --verbose_failures
build --color=yes
build --keep_going

# CI / caching
# Enables Bazel's local disk cache. When ~/.cache/bazel is restored by
# actions/cache in CI, Bazel reuses previous build outputs and skips
# re-downloading external deps.
build --disk_cache=~/.cache/bazel/disk-cache

# Test UX
test --test_output=errors

# Toolchain configs
# --config=clang  Uses the pinned LLVM toolchain (see MODULE.bazel: toolchains_llvm).
#                 Intended for Linux x86_64.  On macOS, omit this flag to use the
#                 system Xcode Clang, which works with all dependencies including gRPC.
build:clang --extra_toolchains=@llvm_toolchain//:cc-toolchain-x86_64-linux
