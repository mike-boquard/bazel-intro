{
  // rust-analyzer: use the Bazel-generated rust-project.json instead of Cargo.
  // Run `bazel run //:gen_rust_project` (or ./scripts/refresh_rust_project.sh)
  // to regenerate after adding new Rust targets.
  "rust-analyzer.linkedProjects": [
    "rust-project.json"
  ],

  // Prevents rust-analyzer from running `cargo metadata` against the sysroot.
  // Primary fix: refresh_rust_project.sh strips the `sysroot` field from
  // rust-project.json so rust-analyzer never attempts the cargo call.
  // This setting is a belt-and-suspenders guard for newer rust-analyzer versions.
  "rust-analyzer.cargo.sysrootQueryMetadata": false,

  // clangd: compile_commands.json is generated by `bazel run //:refresh_compile_commands`.
  // No extra setting needed — clangd finds it at the workspace root automatically.
}
